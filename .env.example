# Realm URL where you registered the OAuth application (no trailing slash).
# Dev examples:
#   http://zulip.zulipdev.com:9991
#   http://127.0.0.1:9991
ZULIP_REALM_URL=http://zulip.zulipdev.com:9991

# From Zulip → /o/applications/ after registering an app.
ZULIP_CLIENT_ID=
ZULIP_CLIENT_SECRET=

# Must exactly match a redirect URI on the OAuth application.
OAUTH_REDIRECT_URI=http://127.0.0.1:5050/callback

# Local showcase server
FLASK_HOST=127.0.0.1
FLASK_PORT=5050
FLASK_SECRET_KEY=dev-only-change-me
